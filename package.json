{
  "name": "scid-ts",
  "version": "0.1.0",
  "description": "Read SCID chess database files (.si4/.si5) in TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
